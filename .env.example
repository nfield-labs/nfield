# FormatShield API Keys
# ─────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your keys below
# 3. That's it — FormatShield loads .env automatically on import.
#    No export, no shell setup, no activation needed.
#
# NEVER commit .env to git (it is already in .gitignore)
# ─────────────────────────────────────────────────

# Groq backend (free tier at groq.com — fastest inference)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter backend (openrouter.ai — 200+ models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama and vLLM run locally — no API key needed.
# Override the default host/URL here if needed:
# OLLAMA_HOST=http://localhost:11434
# VLLM_BASE_URL=http://localhost:8000/v1
